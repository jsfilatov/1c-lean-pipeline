{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/1c-lean-pipeline/handoff-response.schema.json",
  "title": "1c-lean-pipeline HandoffResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_dir",
    "call_id",
    "target_subagent",
    "chat_summary",
    "primary_artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "task_dir": { "type": "string" },
    "call_id": {
      "type": "string",
      "description": "Должен совпадать с call_id из соответствующего HandoffRequest"
    },
    "target_subagent": { "type": "string" },
    "chat_summary": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "type": "string" },
      "description": "3–7 коротких строк для чата пользователю (допускается до 10 при списке путей)"
    },
    "primary_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Пути к обновлённым файлам артефактов"
    },
    "changed_source_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Пути под src/cf/**, src/cfe/** при фазах 6/8"
    },
    "notes": {
      "type": "string",
      "description": "Необязательные служебные заметки для оркестратора"
    }
  }
}
