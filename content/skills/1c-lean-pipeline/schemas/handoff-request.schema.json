{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/1c-lean-pipeline/handoff-request.schema.json",
  "title": "1c-lean-pipeline HandoffRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_dir",
    "openspec_change",
    "call_id",
    "target_subagent",
    "phase"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "task_dir": {
      "type": "string",
      "description": "Каталог задачи, напр. .tasks/task-my-feature"
    },
    "openspec_change": {
      "type": "string",
      "description": "Активный OpenSpec change, напр. openspec/changes/my-feature. Обязателен для SDD-конвейера"
    },
    "call_id": {
      "type": "string",
      "description": "Уникальный id вызова (UTC ISO или uuid) для сопоставления с response"
    },
    "target_subagent": {
      "type": "string",
      "description": "Имя субагента (subagent_type), напр. 1c-analytic"
    },
    "phase": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "feature_slug": {
      "type": "string"
    },
    "complexity": {
      "type": "string",
      "enum": ["простая", "средняя", "сложная", "критичная"]
    },
    "focus": {
      "type": "string",
      "description": "Одна строка фокуса исследования / таска / ревью"
    },
    "task_id": {
      "type": "string",
      "pattern": "^T-[0-9]{2}$",
      "description": "Для фаз 6/8: идентификатор подзадачи"
    },
    "req_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^REQ-[0-9]{2}$"
      }
    },
    "files_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Полные пути к файлам области ревью/правок"
    },
    "read_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Доп. пути только при отсутствии среза в slices (fallback)"
    },
    "write_hint": {
      "type": "string",
      "description": "Краткая подсказка оркестратора, куда писать результат"
    },
    "gate_documents": {
      "type": "object",
      "additionalProperties": false,
      "description": "Фазозависимые OpenSpec gate-документы. Для фаз 0–2 может быть пустым; proposal появляется с фазы 3, design — с фазы 4, tasks — с фазы 5",
      "properties": {
        "proposal": { "$ref": "#/$defs/gateDocumentRef" },
        "design": { "$ref": "#/$defs/gateDocumentRef" },
        "tasks": { "$ref": "#/$defs/gateDocumentRef" }
      }
    },
    "spec_deltas": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Опциональные пути к delta specs под openspec/changes/<change-id>/specs/**/spec.md; содержимое не встраивать"
    },
    "slices": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phase0_summary": { "type": "string" },
        "phase1_summary": { "type": "string" },
        "discovery_summary": { "$ref": "#/$defs/discoverySummary" },
        "architecture_section_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "req_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/reqItem" }
        },
        "task_slice": { "$ref": "#/$defs/taskSlice" },
        "context_index_for_task": { "type": "string" },
        "code_review_summary": { "type": "string" }
      }
    },
    "anchors": {
      "type": "array",
      "items": { "$ref": "#/$defs/codeAnchor" }
    }
  },
  "$defs": {
    "gateDocumentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "source_revision"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Путь к proposal.md / design.md / tasks.md в openspec/changes/<change-id>"
        },
        "source_revision": {
          "type": "integer",
          "minimum": 0,
          "description": "Монотонный счётчик; оркестратор увеличивает после правок пользователя на gate"
        },
        "content_sha256": {
          "type": "string",
          "description": "Опционально: хэш содержимого на момент сборки handoff"
        }
      }
    },
    "codeAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "label": { "type": "string" }
      }
    },
    "discoverySummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hypotheses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confirmed_chains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modification_points": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "reqItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "pattern": "^REQ-[0-9]{2}$" },
        "title": { "type": "string" },
        "acceptance": { "type": "string" }
      }
    },
    "taskSlice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "pattern": "^T-[0-9]{2}$" },
        "title": { "type": "string" },
        "done_criteria": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
